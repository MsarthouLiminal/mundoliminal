---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="tagline">Contexto · Mecanismo · Consecuencia</p>
  <p class="meta">© {year} LIMINAL · mundoliminal.com</p>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    padding: var(--space-8);
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
    text-align: center;
  }
  .tagline {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: 700;
    letter-spacing: var(--tracking-display-wide);
    text-transform: uppercase;
    color: var(--color-hueso);
  }
  .meta {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-ceniza);
  }
</style>
