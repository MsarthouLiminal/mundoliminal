---
import Logo from '../brand/Logo.astro';
import Nav from './Nav.astro';

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
---

<header class="site-header">
  {!isHome && (
    <a href="/" class="brand" aria-label="LIMINAL — inicio">
      <Logo variant="oscura" width={140} />
    </a>
  )}
  <Nav />
</header>

<style>
  .site-header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-6) var(--space-8);
    border-bottom: 1px solid var(--rule);
  }
  /* Cuando no hay logo (home), .brand no se renderiza:
     la primera columna queda vacía y el nav queda anclado a la derecha. */
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    justify-self: start;
  }

  @media (max-width: 720px) {
    .site-header {
      grid-template-columns: 1fr;
      gap: var(--space-4);
      padding: var(--space-4);
    }
  }
</style>
