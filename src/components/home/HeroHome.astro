---
import Logo from '../brand/Logo.astro';
import NewsletterCTA from './NewsletterCTA.astro';
---

<section class="hero">
  <div class="hero__brand">
    <Logo variant="oscura" width={520} alt="LIMINAL" />
    <p class="hero__phrase">Señales que importan.</p>
  </div>

  <p class="hero__promise">
    <span>Leer el presente como un sistema.</span>
    <span>Anticipar las consecuencias.</span>
    <span>Decodificar las señales que importan.</span>
  </p>

  <p class="hero__intro">
    Un proyecto editorial sobre geopolítica, tecnología y economía.
    Los tres territorios donde se juega el poder de nuestro tiempo.
    Por Martín Sarthou.
  </p>

  <NewsletterCTA variant="hero" />
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    align-items: center;
    text-align: center;
    padding: var(--space-16) var(--space-4) var(--space-12);
    background-image:
      linear-gradient(rgba(6, 12, 8, 0.55), rgba(6, 12, 8, 0.55)),
      url('/images/hero-background.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .hero__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: center;
    width: 100%;
  }
  .hero__phrase {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--fs-md);
    letter-spacing: var(--tracking-display-wide);
    text-transform: uppercase;
    color: var(--color-ocre);
  }
  .hero__promise {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1rem, 2.4vw, 1.5rem);
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
    line-height: 1.3;
    color: var(--color-hueso);
  }
  .hero__promise > span {
    display: block;
    white-space: nowrap;
  }
  .hero__promise > span + span {
    margin-top: var(--space-2);
  }
  .hero__intro {
    font-family: var(--font-mono);
    font-size: var(--fs-base);
    color: var(--color-hueso);
    max-width: var(--content-max);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  @media (max-width: 720px) {
    .hero {
      padding: var(--space-8) 0 var(--space-6);
    }
    .hero__promise > span {
      white-space: normal;
    }
    .hero__intro {
      text-align: left;
    }
  }
</style>
