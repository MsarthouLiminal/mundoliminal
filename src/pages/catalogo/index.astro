---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PILLARS } from '../../lib/pillars';
---

<BaseLayout title="Catálogo">
  <article>
    <header class="catalog-head">
      <h1>Catálogo</h1>
      <p class="placeholder">[PLACEHOLDER: descripción del catálogo — episodios y columnas, pendiente de redacción.]</p>
    </header>

    <ul class="pillars">
      {PILLARS.map((p) => (
        <li class="pillar">
          <a href={`/catalogo/${p.slug}`}>
            <span class="pillar__code">{p.code}</span>
            <span class="pillar__label">{p.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</BaseLayout>

<style>
  article {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .catalog-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--content-max);
  }
  h1 {
    font-size: var(--fs-3xl);
    letter-spacing: var(--tracking-display-wide);
  }
  .placeholder {
    color: color-mix(in oklab, var(--color-hueso) 60%, transparent);
    font-style: italic;
    max-width: 60ch;
  }
  .pillars {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-4);
  }
  .pillar a {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    border: 1px solid var(--rule);
    text-decoration: none;
    color: var(--color-hueso);
    transition: border-color 150ms, color 150ms;
  }
  .pillar a:hover {
    border-color: var(--color-teal-brillante);
    color: var(--color-teal-brillante);
  }
  .pillar__code {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--color-teal-brillante);
    letter-spacing: var(--tracking-display);
  }
  .pillar__label {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-display);
  }
</style>
