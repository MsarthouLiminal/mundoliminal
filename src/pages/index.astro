---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroHome from '../components/home/HeroHome.astro';
import LatestCard from '../components/home/LatestCard.astro';
import Manifesto from '../components/home/Manifesto.astro';
import CommercialBlock from '../components/home/CommercialBlock.astro';
import {
  getYouTubeLatest,
  getSubstackLatest,
  getSpotifyLatest,
  type LatestItem,
} from '../lib/feeds';

const settled = await Promise.allSettled([
  getYouTubeLatest(),
  getSubstackLatest(),
  getSpotifyLatest(),
]);
const [yt, sb, sp] = settled.map((r): LatestItem | null =>
  r.status === 'fulfilled' ? r.value : null,
);
---

<BaseLayout title="LIMINAL">
  <HeroHome />

  <section class="latest" aria-labelledby="latest-heading">
    <h2 id="latest-heading" class="latest__title">Últimos de LIMINAL.</h2>
    <ul class="latest__grid">
      <li>
        <LatestCard
          item={yt}
          platform="youtube"
          fallbackHref="https://www.youtube.com/@trimaxmediaok"
        />
      </li>
      <li>
        <LatestCard
          item={sb}
          platform="substack"
          fallbackHref="https://mundoliminal.substack.com"
        />
      </li>
      <li>
        <LatestCard
          item={sp}
          platform="spotify"
          fallbackHref="https://open.spotify.com/show/5iy7NKRkKbcOZxLzld1nNX"
        />
      </li>
    </ul>
  </section>

  <Manifesto />

  <CommercialBlock />
</BaseLayout>

<style>
  .latest {
    margin-top: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .latest__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-md);
    letter-spacing: var(--tracking-display-wide);
    text-transform: uppercase;
    color: var(--color-hueso);
    text-align: center;
  }
  .latest__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 720px) {
    .latest__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
